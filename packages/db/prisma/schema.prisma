generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  title         String?
  avatarUrl     String?
  role          String
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  memberships   Membership[]
  vacancies     Vacancy[]     @relation("VacancyCreator")
  evaluations   Evaluation[]
  clientReviews ClientDecision[] @relation("ClientReviewer")
  identities    AuthIdentity[]
  sessions      UserSession[]
  candidates    Candidate[]    @relation("CandidateUser")
  invitedCandidates Candidate[] @relation("CandidateInviter")
  candidateInvitesSent CandidateInvite[] @relation("CandidateInviteActor")
  mfaPreference MfaPreference?
  notificationPreference UserNotificationPreference?
  notificationDispatches NotificationDispatch[]
  smartInterviewReviews SmartInterviewHumanReview[] @relation("SmartInterviewReviewer")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  status      String       @default("active")
  ownerAdminUserId String?
  createdAt   DateTime     @default(now())
  memberships Membership[]
  vacancies   Vacancy[]
  candidates  Candidate[]
  tenantPolicy TenantPolicy?
  tenantSettings TenantSettings?
  tenantPolicyVersions TenantPolicyVersion[]
  rolePolicies RolePolicy[]
  permissionGrants PermissionGrant[]
  communicationTemplates CommunicationTemplate[]
  communicationDispatchAudits CommunicationDispatchAudit[]
  candidateInvites CandidateInvite[]
  notificationDispatches NotificationDispatch[]
  tenantKpiSnapshots TenantKpiSnapshot[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model Vacancy {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  description    String
  location       String?
  workModel      String?
  seniority      String?
  sector         String?
  experienceYearsMin Int?
  experienceYearsMax Int?
  employmentType String?
  publicationType String       @default("draft")
  status         String        @default("active")
  publishedAt    DateTime?
  closedAt       DateTime?
  closedBy       String?
  filledAt       DateTime?
  guaranteeEndDate DateTime?
  department     String?
  requiredSkills Json?
  desiredSkills  Json?
  salaryMin      Int?
  salaryMax      Int?
  createdBy      String
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  creator        User          @relation("VacancyCreator", fields: [createdBy], references: [id])
  applications   Application[]
  shortlist      Shortlist?
  smartInterviewTemplates SmartInterviewTemplate[]
  embeddings      VacancyEmbedding[]
  matchingScores  MatchingScore[]
  rankingSnapshots CandidateRankingSnapshot[]
  recommendations CandidateRecommendation[]
  priorityScores  CandidatePriorityScore[]
  workflowSuggestions WorkflowSuggestion[]
  automationExecutions AutomationExecution[]
  riskSignals     RiskSignal[]
  riskEvaluations RiskEvaluation[]
  templates       VacancyTemplate[]
  candidateInvites CandidateInvite[]
}

model Candidate {
  id             String                      @id @default(cuid())
  organizationId String
  email          String                      @unique
  phone          String?                     @unique
  token          String                      @unique
  createdAt      DateTime                    @default(now())
  invitedByUserId String?
  userId         String?
  guestUpgradeAt DateTime?
  organization   Organization                @relation(fields: [organizationId], references: [id])
  profile        CandidateProfile?
  applications   Application[]
  onboarding     CandidateOnboardingSession?
  smartInterviewAnswers SmartInterviewAnswer[]
  embeddings      CandidateEmbedding[]
  matchingScores  MatchingScore[]
  insights        CandidateInsight[]
  leftComparisons CandidateComparison[] @relation("ComparisonLeftCandidate")
  rightComparisons CandidateComparison[] @relation("ComparisonRightCandidate")
  rankingSnapshots CandidateRankingSnapshot[]
  aiEvidences     AiEvidence[]
  aiExplanations  AiExplanation[]
  recommendations CandidateRecommendation[]
  priorityScores  CandidatePriorityScore[]
  workflowSuggestions WorkflowSuggestion[]
  automationExecutions AutomationExecution[]
  riskSignals     RiskSignal[]
  riskEvaluations RiskEvaluation[]
  invitedBy      User?                       @relation("CandidateInviter", fields: [invitedByUserId], references: [id])
  user           User?                       @relation("CandidateUser", fields: [userId], references: [id])
  guestSession   GuestSession?
  invites        CandidateInvite[]
  preferences    CandidatePreferences?
}

model TenantPolicy {
  id                    String       @id @default(cuid())
  organizationId        String       @unique
  canInviteCandidates   Boolean      @default(true)
  canApproveDecisions   Boolean      @default(true)
  canAuditEvents        Boolean      @default(true)
  canAdministrateTenant Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id])
}

model TenantSettings {
  id                      String   @id @default(cuid())
  organizationId          String   @unique
  planSegment             String
  slaResponseHours        Int      @default(24)
  slaClosureHours         Int      @default(336)
  timezone                String
  operationalCalendar     String
  tenantStatus            String   @default("trial")
  logoUrl                 String?
  bannerUrl               String?
  primaryColor            String?
  secondaryColor          String?
  publicName              String?
  communicationDomain     String?
  contactEmail            String?
  defaultFeedbackMessage  String?
  dataRetentionDays       Int      @default(365)
  auditRetentionDays      Int      @default(365)
  mfaRequiredRoles        String[]
  maxSessionMinutes       Int      @default(480)
  communicationWindowStart String @default("08:00")
  communicationWindowEnd   String @default("20:00")
  frequencyLimitPerDay    Int      @default(5)
  riskPenaltyWeight       Float    @default(25)
  recommendationBoostWeight Float  @default(3)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  organization            Organization @relation(fields: [organizationId], references: [id])
  policyVersions          TenantPolicyVersion[]
}

model TenantPolicyVersion {
  id                 String   @id @default(cuid())
  organizationId     String
  tenantSettingsId   String?
  version            Int
  policyJson         Json
  previousPolicyJson Json?
  changedBy          String
  createdAt          DateTime @default(now())
  organization       Organization @relation(fields: [organizationId], references: [id])
  tenantSettings     TenantSettings? @relation(fields: [tenantSettingsId], references: [id])

  @@unique([organizationId, version])
}

model RolePolicy {
  id             String   @id @default(cuid())
  organizationId String
  roleKey        String
  resource       String
  action         String
  scope          String
  allowed        Boolean  @default(true)
  updatedBy      String
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, roleKey, resource, action, scope])
}

model PermissionGrant {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  grantedBy      String
  resource       String
  action         String
  scope          String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, userId, expiresAt])
}

model CommunicationTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String
  channel        String
  placeholders   String[]
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  versions       CommunicationTemplateVersion[]
  dispatchAudits CommunicationDispatchAudit[]
}

model CommunicationTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  status      String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())
  template    CommunicationTemplate @relation(fields: [templateId], references: [id])
  dispatchAudits CommunicationDispatchAudit[]

  @@unique([templateId, version])
}

model CommunicationDispatchAudit {
  id                String   @id @default(cuid())
  organizationId    String
  templateId        String
  templateVersionId String
  recipient         String
  eventKey          String
  channel           String
  status            String
  failureReason     String?
  renderedContent   String?
  idempotencyKey    String   @unique
  requestedBy       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id])
  template          CommunicationTemplate @relation(fields: [templateId], references: [id])
  templateVersion   CommunicationTemplateVersion @relation(fields: [templateVersionId], references: [id])
}

model TenantKpiSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  period         String
  capturedAt     DateTime
  invites        Int      @default(0)
  responses      Int      @default(0)
  shortlisted    Int      @default(0)
  approved       Int      @default(0)
  onboarded      Int      @default(0)
  avgTimeToPublishHours Float @default(0)
  avgInviteToOnboardingHours Float @default(0)
  avgDecisionTimeHours Float @default(0)
  throughputPerHeadhunter Float @default(0)
  slaMet         Int      @default(0)
  slaBreached    Int      @default(0)
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, period, capturedAt])
}

model UserNotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(true)
  phoneEnabled          Boolean  @default(false)
  inAppEnabled          Boolean  @default(true)
  eventNewInvite        Boolean  @default(true)
  eventStepCompleted    Boolean  @default(true)
  eventDecision         Boolean  @default(true)
  eventReminder         Boolean  @default(true)
  eventAccessChange     Boolean  @default(true)
  eventCriticalAudit    Boolean  @default(true)
  frequency             String   @default("immediate")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

model CandidateInvite {
  id             String       @id @default(cuid())
  organizationId String
  vacancyId      String
  candidateId    String
  channel        String
  destination    String
  status         String       @default("queued")
  dispatchId     String?
  invitedByUserId String
  failureReason  String?
  metadata       Json?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  vacancy        Vacancy      @relation(fields: [vacancyId], references: [id])
  candidate      Candidate    @relation(fields: [candidateId], references: [id])
  invitedBy      User         @relation("CandidateInviteActor", fields: [invitedByUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([vacancyId, status])
  @@index([candidateId, createdAt])
}

model NotificationDispatch {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  channel        String
  eventKey       String
  destination    String
  status         String       @default("queued")
  frequency      String       @default("immediate")
  failureReason  String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([organizationId, eventKey, createdAt])
}

model CandidateProfile {
  id                    String    @id @default(cuid())
  candidateId           String    @unique
  fullName              String?
  phone                 String?
  photoUrl              String?
  photoProvider         String?
  socialName            String?
  socialEmail           String?
  introVideoKey         String?
  introVideoProvider    String?
  introVideoDurationSec Int?
  introVideoUploadedAt  DateTime?
  candidate             Candidate @relation(fields: [candidateId], references: [id])
}

model Application {
  id          String       @id @default(cuid())
  candidateId String
  vacancyId   String
  status      String       @default("submitted")
  createdAt   DateTime     @default(now())
  candidate   Candidate    @relation(fields: [candidateId], references: [id])
  vacancy     Vacancy      @relation(fields: [vacancyId], references: [id])
  evaluations Evaluation[]
  shortlistItems ShortlistItem[]
  smartInterviewSessions SmartInterviewSession[]

  @@unique([candidateId, vacancyId])
}

model CandidateOnboardingSession {
  id                    String              @id @default(cuid())
  candidateId           String              @unique
  basicCompleted        Boolean             @default(false)
  consentCompleted      Boolean             @default(false)
  resumeCompleted       Boolean             @default(false)
  preferencesCompleted  Boolean             @default(false)
  introVideoCompleted   Boolean             @default(false)
  status                String              @default("pending")
  candidate             Candidate           @relation(fields: [candidateId], references: [id])
  consents              CandidateConsent[]
  resumes               CandidateResume[]
}

model CandidateConsent {
  id            String                      @id @default(cuid())
  sessionId     String
  type          String
  accepted      Boolean
  acceptedAt    DateTime                    @default(now())
  session       CandidateOnboardingSession  @relation(fields: [sessionId], references: [id])
}

model CandidatePreferences {
  id          String    @id @default(cuid())
  candidateId String    @unique
  salaryMin   Int?
  salaryMax   Int?
  jobTitles   String[]
  languages   String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id])
}

model CandidateResume {
  id            String                      @id @default(cuid())
  sessionId     String
  objectKey     String
  provider      String
  status        String                      @default("uploaded")
  uploadedAt    DateTime                    @default(now())
  session       CandidateOnboardingSession  @relation(fields: [sessionId], references: [id])
  parseResult   ResumeParseResult?
  parseMetadata ResumeParseMetadata?
}

model ResumeParseResult {
  id          String          @id @default(cuid())
  resumeId    String          @unique
  status      String
  parsedJson  Json
  createdAt   DateTime        @default(now())
  resume      CandidateResume @relation(fields: [resumeId], references: [id])
}

model Shortlist {
  id          String          @id @default(cuid())
  vacancyId   String          @unique
  createdAt   DateTime        @default(now())
  vacancy     Vacancy         @relation(fields: [vacancyId], references: [id])
  items       ShortlistItem[]
}

model ShortlistItem {
  id            String       @id @default(cuid())
  shortlistId   String
  applicationId String
  createdAt     DateTime     @default(now())
  shortlist     Shortlist    @relation(fields: [shortlistId], references: [id])
  application   Application  @relation(fields: [applicationId], references: [id])
  decisions     ClientDecision[]

  @@unique([shortlistId, applicationId])
}

model Evaluation {
  id                  String       @id @default(cuid())
  applicationId       String
  evaluatorId         String
  comment             String
  ratingTechnical     Int?
  ratingBehavioral    Int?
  ratingInterviewer   Int?
  ratingAi            Int?
  overallRating       Float?
  createdAt           DateTime     @default(now())
  application         Application  @relation(fields: [applicationId], references: [id])
  evaluator           User         @relation(fields: [evaluatorId], references: [id])
}

model ClientDecision {
  id             String        @id @default(cuid())
  shortlistItemId String
  reviewerId     String
  decision       String
  createdAt      DateTime      @default(now())
  shortlistItem  ShortlistItem @relation(fields: [shortlistItemId], references: [id])
  reviewer       User          @relation("ClientReviewer", fields: [reviewerId], references: [id])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json
  createdAt   DateTime @default(now())
}

model MessageDispatch {
  id          String   @id @default(cuid())
  channel     String
  destination String
  content     String
  status      String   @default("queued")
  createdAt   DateTime @default(now())
  events      MessageEvent[]
}

model OutboxEvent {
  id          String   @id @default(cuid())
  topic       String
  payload     Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model VacancyTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sector         String
  role           String
  version        Int      @default(1)
  status         String   @default("draft")
  isFavorite     Boolean  @default(false)
  usageCount     Int      @default(0)
  defaultFields  Json
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  vacancyId      String?
  vacancy        Vacancy? @relation(fields: [vacancyId], references: [id])
  versions       VacancyTemplateVersion[]

  @@index([organizationId, status])
}

model VacancyTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  status      String
  fields      Json
  createdBy   String
  createdAt   DateTime @default(now())
  template    VacancyTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, version])
}

model InviteFollowUpCadence {
  id             String   @id @default(cuid())
  organizationId String
  vacancyId      String
  candidateId    String
  applicationId  String?
  channelPlan    Json
  status         String   @default("active")
  pausedUntil    DateTime?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  attempts       InviteFollowUpAttempt[]

  @@unique([candidateId, vacancyId])
  @@index([organizationId, status])
}

model InviteFollowUpAttempt {
  id          String   @id @default(cuid())
  cadenceId   String
  stepKey     String
  channel     String
  status      String   @default("queued")
  scheduledAt DateTime
  sentAt      DateTime?
  metadata    Json
  createdAt   DateTime @default(now())
  cadence     InviteFollowUpCadence @relation(fields: [cadenceId], references: [id])

  @@unique([cadenceId, stepKey])
  @@index([status, scheduledAt])
}

model AuthIdentity {
  id          String   @id @default(cuid())
  provider    String
  subject     String
  email       String?
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([provider, subject])
}

model UserSession {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  provider   String
  expiresAt  DateTime
  revokedAt  DateTime?
  metadata   Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model GuestSession {
  id         String    @id @default(cuid())
  candidateId String   @unique
  token      String    @unique
  expiresAt  DateTime
  upgradedAt DateTime?
  createdAt  DateTime  @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id])
}

model MfaPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  enabled        Boolean  @default(false)
  preferredMethod String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}


model SmartInterviewTemplate {
  id             String   @id @default(cuid())
  vacancyId      String   @unique
  configJson     Json
  status         String   @default("draft")
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  vacancy        Vacancy  @relation(fields: [vacancyId], references: [id])
  questions      SmartInterviewQuestion[]
  sessions       SmartInterviewSession[]
}

model SmartInterviewQuestion {
  id          String   @id @default(cuid())
  templateId  String
  orderIndex  Int
  prompt      String
  maxDuration Int      @default(120)
  source      String   @default("manual")
  createdAt   DateTime @default(now())
  template    SmartInterviewTemplate @relation(fields: [templateId], references: [id])
  answers     SmartInterviewAnswer[]

  @@unique([templateId, orderIndex])
}

model SmartInterviewSession {
  id            String   @id @default(cuid())
  applicationId String   @unique
  templateId    String
  publicToken   String   @unique
  status        String   @default("draft")
  startedAt     DateTime?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  application   Application @relation(fields: [applicationId], references: [id])
  template      SmartInterviewTemplate @relation(fields: [templateId], references: [id])
  answers       SmartInterviewAnswer[]
  aiAnalysis    SmartInterviewAiAnalysis?
  humanReview   SmartInterviewHumanReview?
}

model SmartInterviewAnswer {
  id           String   @id @default(cuid())
  sessionId     String
  questionId    String
  candidateId   String
  objectKey     String
  provider      String
  durationSec   Int?
  status        String   @default("uploaded")
  uploadedAt    DateTime @default(now())
  processedAt   DateTime?
  session       SmartInterviewSession @relation(fields: [sessionId], references: [id])
  question      SmartInterviewQuestion @relation(fields: [questionId], references: [id])
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  transcript    SmartInterviewTranscript?
  transcriptMeta TranscriptMetadata?

  @@unique([sessionId, questionId])
}

model SmartInterviewTranscript {
  id          String   @id @default(cuid())
  answerId    String   @unique
  status      String   @default("pending")
  content     String
  language    String   @default("pt-BR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answer      SmartInterviewAnswer @relation(fields: [answerId], references: [id])
}

model SmartInterviewAiAnalysis {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  status         String   @default("pending")
  summary        String
  highlights     Json
  risks          Json
  evidence       Json?
  sentimentJson  Json?
  entitiesJson   Json?
  keyPhrasesJson Json?
  provider       String   @default("ai-mock")
  modelVersion   String   @default("mock-v1")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  session        SmartInterviewSession @relation(fields: [sessionId], references: [id])
}

model SmartInterviewHumanReview {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  reviewerId  String
  decision    String
  notes       String
  createdAt   DateTime @default(now())
  session     SmartInterviewSession @relation(fields: [sessionId], references: [id])
  reviewer    User     @relation("SmartInterviewReviewer", fields: [reviewerId], references: [id])
}

model FeatureFlag {
  id         String   @id @default(cuid())
  key        String   @unique
  enabled    Boolean  @default(false)
  scope      String   @default("global")
  metadata   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model IntegrationConnection {
  id            String   @id @default(cuid())
  integration   String
  provider      String
  environment   String
  status        String   @default("inactive")
  configJson    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([integration, environment])
}

model ProviderExecutionLog {
  id             String   @id @default(cuid())
  integration    String
  provider       String
  operation      String
  status         String
  idempotencyKey String?
  requestJson    Json
  responseJson   Json
  createdAt      DateTime @default(now())
}

model AiExecutionLog {
  id            String   @id @default(cuid())
  operation     String
  provider      String
  modelVersion  String
  promptVersion String
  status        String
  requestJson   Json
  responseJson  Json
  createdAt     DateTime @default(now())
}

model SocialIdentityLink {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  subject     String
  profileJson Json
  createdAt   DateTime @default(now())

  @@unique([provider, subject])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  status      String
  payload     Json
  createdAt   DateTime @default(now())
}

model TranscriptMetadata {
  id          String   @id @default(cuid())
  answerId    String   @unique
  provider    String
  status      String
  retries     Int      @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  answer      SmartInterviewAnswer @relation(fields: [answerId], references: [id])
}

model ResumeParseMetadata {
  id             String   @id @default(cuid())
  resumeId        String   @unique
  provider        String
  status          String
  confidenceJson  Json
  mergedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resume          CandidateResume @relation(fields: [resumeId], references: [id])
}

model MessageEvent {
  id                String   @id @default(cuid())
  dispatchId        String
  provider          String
  eventType         String
  providerMessageId String
  metadata          Json
  createdAt         DateTime @default(now())
  dispatch          MessageDispatch @relation(fields: [dispatchId], references: [id])

  @@index([provider, providerMessageId])
}

model CandidateEmbedding {
  id          String   @id @default(cuid())
  candidateId String
  source      String   @default("resume+interview")
  vector      Json
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@unique([candidateId, source])
}

model VacancyEmbedding {
  id          String   @id @default(cuid())
  vacancyId   String
  source      String   @default("vacancy-description")
  vector      Json
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vacancy     Vacancy  @relation(fields: [vacancyId], references: [id])

  @@unique([vacancyId, source])
}

model MatchingScore {
  id            String   @id @default(cuid())
  candidateId   String
  vacancyId     String
  score         Float
  modelVersion  String
  status        String   @default("completed")
  computedAt    DateTime @default(now())
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  vacancy       Vacancy  @relation(fields: [vacancyId], references: [id])
  breakdowns    MatchingBreakdown[]
  evidences     AiEvidence[]
  explanations  AiExplanation[]

  @@unique([candidateId, vacancyId])
}

model MatchingBreakdown {
  id             String   @id @default(cuid())
  matchingScoreId String
  dimension      String
  score          Float
  weight         Float
  reasoning      String
  createdAt      DateTime @default(now())
  matchingScore  MatchingScore @relation(fields: [matchingScoreId], references: [id])

  @@unique([matchingScoreId, dimension])
}

model CandidateInsight {
  id          String   @id @default(cuid())
  candidateId String
  vacancyId   String
  summary     String
  strengths   Json
  risks       Json
  recommendations Json
  source      String   @default("ai-assisted")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@unique([candidateId, vacancyId])
}

model CandidateComparison {
  id               String   @id @default(cuid())
  vacancyId        String
  leftCandidateId  String
  rightCandidateId String
  comparisonJson   Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  leftCandidate    Candidate @relation("ComparisonLeftCandidate", fields: [leftCandidateId], references: [id])
  rightCandidate   Candidate @relation("ComparisonRightCandidate", fields: [rightCandidateId], references: [id])

  @@unique([vacancyId, leftCandidateId, rightCandidateId])
}

model CandidateRankingSnapshot {
  id          String   @id @default(cuid())
  vacancyId   String
  candidateId String
  rank        Int
  score       Float
  rationale   String
  manualOverride Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vacancy     Vacancy  @relation(fields: [vacancyId], references: [id])
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  @@unique([vacancyId, candidateId])
  @@unique([vacancyId, rank])
}

model AiEvidence {
  id             String   @id @default(cuid())
  candidateId    String
  matchingScoreId String?
  sourceType     String
  sourceRef      String
  excerpt        String
  confidence     Float
  metadata       Json
  createdAt      DateTime @default(now())
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  matchingScore  MatchingScore? @relation(fields: [matchingScoreId], references: [id])
}

model AiExplanation {
  id             String   @id @default(cuid())
  candidateId    String
  matchingScoreId String?
  context        String
  explanation    String
  generatedBy    String
  createdAt      DateTime @default(now())
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  matchingScore  MatchingScore? @relation(fields: [matchingScoreId], references: [id])
}

model StorageAssetMetadata {
  id         String   @id @default(cuid())
  tenantId   String
  objectKey  String   @unique
  category   String
  provider   String
  metadata   Json
  createdAt  DateTime @default(now())
}

model CandidateRecommendation {
  id                String   @id @default(cuid())
  candidateId       String
  vacancyId         String
  recommendationType String
  title             String
  explanation       String
  confidence        Float
  actionableInsights Json
  status            String   @default("active")
  source            String   @default("ai-assisted")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  candidate         Candidate @relation(fields: [candidateId], references: [id])
  vacancy           Vacancy   @relation(fields: [vacancyId], references: [id])

  @@index([vacancyId, status])
  @@index([candidateId, vacancyId])
}

model CandidatePriorityScore {
  id             String   @id @default(cuid())
  candidateId    String
  vacancyId      String
  score          Float
  priorityBand   String
  factors        Json
  rationale      String
  manualOverride Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  vacancy        Vacancy   @relation(fields: [vacancyId], references: [id])

  @@unique([candidateId, vacancyId])
  @@index([vacancyId, score])
}

model WorkflowSuggestion {
  id                   String   @id @default(cuid())
  candidateId          String
  vacancyId            String
  suggestionType       String
  payload              Json
  explanation          String
  requiresHumanApproval Boolean @default(true)
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  candidate            Candidate @relation(fields: [candidateId], references: [id])
  vacancy              Vacancy   @relation(fields: [vacancyId], references: [id])
  automationExecutions AutomationExecution[]

  @@index([vacancyId, status])
}

model AutomationExecution {
  id                   String   @id @default(cuid())
  candidateId          String
  vacancyId            String
  workflowSuggestionId String?
  action               String
  status               String   @default("queued")
  inputJson            Json
  outputJson           Json
  triggeredBy          String?
  executedAt           DateTime?
  createdAt            DateTime @default(now())
  candidate            Candidate @relation(fields: [candidateId], references: [id])
  vacancy              Vacancy   @relation(fields: [vacancyId], references: [id])
  suggestion           WorkflowSuggestion? @relation(fields: [workflowSuggestionId], references: [id])

  @@index([vacancyId, status])
}

model RiskSignal {
  id          String   @id @default(cuid())
  candidateId String
  vacancyId   String
  signalType  String
  severity    String
  score       Float
  details     Json
  status      String   @default("active")
  createdAt   DateTime @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  vacancy     Vacancy   @relation(fields: [vacancyId], references: [id])

  @@index([vacancyId, severity])
  @@index([vacancyId, status])
}

model RiskEvaluation {
  id             String    @id @default(cuid())
  candidateId    String
  vacancyId      String
  overallRisk    String
  riskScore      Float
  findings       Json
  explanation    String
  requiresReview Boolean   @default(true)
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewAction   String?
  reviewReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  candidate      Candidate @relation(fields: [candidateId], references: [id])
  vacancy        Vacancy   @relation(fields: [vacancyId], references: [id])

  @@unique([candidateId, vacancyId])
}
