DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connekt
APP_ENV=local
VITE_API_URL=http://localhost:3000
VITE_CANDIDATE_WEB_URL=http://localhost:5174

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Feature flags - real integrations disabled for local development
FF_STORAGE_REAL=false
FF_EMAIL_REAL=false
FF_AUTH_REAL=false
FF_AI_REAL=false
FF_CV_PARSER_REAL=false
FF_TRANSCRIPTION_REAL=false

# Fallback control
STORAGE_FALLBACK_TO_MOCK=true
EMAIL_FALLBACK_TO_MOCK=true
AUTH_FALLBACK_TO_MOCK=true
AI_FALLBACK_TO_MOCK=true
CV_PARSER_FALLBACK_TO_MOCK=true
TRANSCRIPTION_FALLBACK_TO_MOCK=true

# Explicit provider override (optional)
STORAGE_PROVIDER=auto
EMAIL_PROVIDER=auto
AUTH_PROVIDER=auto
AI_PROVIDER=auto
CV_PARSER_PROVIDER=auto
TRANSCRIPTION_PROVIDER=auto

# AWS S3 / MinIO
AWS_REGION=us-east-1
S3_REGION=us-east-1
S3_BUCKET=connekt-staging-assets
S3_ENDPOINT=http://host.docker.internal:9000
S3_PUBLIC_ENDPOINT=http://host.docker.internal:9000
S3_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=miniopassword
AWS_SESSION_TOKEN=

# AWS SES
SES_REGION=us-east-1
SES_FROM_EMAIL=__REPLACE_ME__

# AWS Cognito (backoffice - admin/headhunter/client)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
COGNITO_LOGOUT_URI=http://localhost:5173

# AWS Cognito - Candidate Pool
COGNITO_CANDIDATE_POOL_ID=
COGNITO_CANDIDATE_CLIENT_ID=
COGNITO_CANDIDATE_CLIENT_SECRET=
COGNITO_CANDIDATE_DOMAIN=
COGNITO_CANDIDATE_REDIRECT_URI=http://localhost:5174/auth/callback
COGNITO_CANDIDATE_LOGOUT_URI=http://localhost:5174
CANDIDATE_WEB_URL=http://localhost:5174

# AI
AI_MODEL_VERSION=gpt-4.1-mini
AI_PROVIDER_API_KEY=
OPENAI_API_KEY=
OPENAI_TIMEOUT_MS=30000

# AWS Transcribe
AWS_TRANSCRIBE_REGION=us-east-1

# AWS Comprehend
AWS_COMPREHEND_REGION=us-east-1

# Redis (rate limiting + token cache)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
WORKER_POLL_INTERVAL_SEC=5
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=30
PUBLIC_TOKEN_CACHE_TTL_SEC=30
