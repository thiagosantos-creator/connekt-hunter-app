generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  title         String?
  avatarUrl     String?
  role          String
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  memberships   Membership[]
  vacancies     Vacancy[]     @relation("VacancyCreator")
  evaluations   Evaluation[]
  clientReviews ClientDecision[] @relation("ClientReviewer")
  identities    AuthIdentity[]
  sessions      UserSession[]
  candidates    Candidate[]    @relation("CandidateUser")
  invitedCandidates Candidate[] @relation("CandidateInviter")
  candidateInvitesSent CandidateInvite[] @relation("CandidateInviteActor")
  mfaPreference MfaPreference?
  notificationPreference UserNotificationPreference?
  notificationDispatches NotificationDispatch[]
  smartInterviewReviews SmartInterviewHumanReview[] @relation("SmartInterviewReviewer")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  status      String       @default("active")
  ownerAdminUserId String?
  createdAt   DateTime     @default(now())
  memberships Membership[]
  vacancies   Vacancy[]
  candidates  Candidate[]
  tenantPolicy TenantPolicy?
  tenantSettings TenantSettings?
  tenantPolicyVersions TenantPolicyVersion[]
  rolePolicies RolePolicy[]
  permissionGrants PermissionGrant[]
  communicationTemplates CommunicationTemplate[]
  communicationDispatchAudits CommunicationDispatchAudit[]
  candidateInvites CandidateInvite[]
  notificationDispatches NotificationDispatch[]
  tenantKpiSnapshots TenantKpiSnapshot[]
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Vacancy {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  description    String
  location       String?
  workModel      String?
  seniority      String?
  sector         String?
  experienceYearsMin Int?
  experienceYearsMax Int?
  employmentType String?
  publicationType String       @default("draft")
  status         String        @default("active")
  publishedAt    DateTime?
  closedAt       DateTime?
  closedBy       String?
  filledAt       DateTime?
  guaranteeEndDate DateTime?
  department     String?
  requiredSkills Json?
  desiredSkills  Json?
  salaryMin      Int?
  salaryMax      Int?
  createdBy      String
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User          @relation("VacancyCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  applications   Application[]
  shortlist      Shortlist?
  smartInterviewTemplates SmartInterviewTemplate[]
  embeddings      VacancyEmbedding[]
  matchingScores  MatchingScore[]
  rankingSnapshots CandidateRankingSnapshot[]
  recommendations CandidateRecommendation[]
  priorityScores  CandidatePriorityScore[]
  workflowSuggestions WorkflowSuggestion[]
  automationExecutions AutomationExecution[]
  riskSignals     RiskSignal[]
  riskEvaluations RiskEvaluation[]
  templates       VacancyTemplate[]
  candidateInvites CandidateInvite[]
  isVerified     Boolean       @default(true)
  clientReviewSessions ClientReviewSession[]
}

model Candidate {
  id             String                      @id @default(cuid())
  organizationId String
  email          String                      @unique
  phone          String?                     @unique
  token          String                      @unique
  createdAt      DateTime                    @default(now())
  invitedByUserId String?
  userId         String?
  guestUpgradeAt DateTime?
  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile        CandidateProfile?
  applications   Application[]
  onboarding     CandidateOnboardingSession?
  smartInterviewAnswers SmartInterviewAnswer[]
  embeddings      CandidateEmbedding[]
  matchingScores  MatchingScore[]
  insights        CandidateInsight[]
  leftComparisons CandidateComparison[] @relation("ComparisonLeftCandidate")
  rightComparisons CandidateComparison[] @relation("ComparisonRightCandidate")
  rankingSnapshots CandidateRankingSnapshot[]
  aiEvidences     AiEvidence[]
  aiExplanations  AiExplanation[]
  recommendations CandidateRecommendation[]
  priorityScores  CandidatePriorityScore[]
  workflowSuggestions WorkflowSuggestion[]
  automationExecutions AutomationExecution[]
  riskSignals     RiskSignal[]
  riskEvaluations RiskEvaluation[]
  invitedBy      User?                       @relation("CandidateInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  user           User?                       @relation("CandidateUser", fields: [userId], references: [id], onDelete: SetNull)
  guestSession   GuestSession?
  invites        CandidateInvite[]
  preferences    CandidatePreferences?

  @@index([organizationId])
}

model TenantPolicy {
  id                    String       @id @default(cuid())
  organizationId        String       @unique
  canInviteCandidates   Boolean      @default(true)
  canApproveDecisions   Boolean      @default(true)
  canAuditEvents        Boolean      @default(true)
  canAdministrateTenant Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TenantSettings {
  id                      String   @id @default(cuid())
  organizationId          String   @unique
  planSegment             String
  slaResponseHours        Int      @default(24)
  slaClosureHours         Int      @default(336)
  timezone                String
  operationalCalendar     String
  tenantStatus            String   @default("trial")
  logoUrl                 String?
  bannerUrl               String?
  primaryColor            String?
  secondaryColor          String?
  publicName              String?
  communicationDomain     String?
  contactEmail            String?
  defaultFeedbackMessage  String?
  dataRetentionDays       Int      @default(365)
  auditRetentionDays      Int      @default(365)
  mfaRequiredRoles        String[]
  maxSessionMinutes       Int      @default(480)
  communicationWindowStart String @default("08:00")
  communicationWindowEnd   String @default("20:00")
  frequencyLimitPerDay    Int      @default(5)
  riskPenaltyWeight       Float    @default(25)
  recommendationBoostWeight Float  @default(3)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policyVersions          TenantPolicyVersion[]
}

model TenantPolicyVersion {
  id                 String   @id @default(cuid())
  organizationId     String
  tenantSettingsId   String?
  version            Int
  policyJson         Json
  previousPolicyJson Json?
  changedBy          String
  createdAt          DateTime @default(now())
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantSettings     TenantSettings? @relation(fields: [tenantSettingsId], references: [id], onDelete: SetNull)

  @@unique([organizationId, version])
}

model RolePolicy {
  id             String   @id @default(cuid())
  organizationId String
  roleKey        String
  resource       String
  action         String
  scope          String
  allowed        Boolean  @default(true)
  updatedBy      String
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, roleKey, resource, action, scope])
}

model PermissionGrant {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  grantedBy      String
  resource       String
  action         String
  scope          String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, expiresAt])
}

model CommunicationTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String
  channel        String
  placeholders   String[]
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       CommunicationTemplateVersion[]
  dispatchAudits CommunicationDispatchAudit[]
}

model CommunicationTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  status      String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())
  template    CommunicationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dispatchAudits CommunicationDispatchAudit[]

  @@unique([templateId, version])
}

model CommunicationDispatchAudit {
  id                String   @id @default(cuid())
  organizationId    String
  templateId        String
  templateVersionId String
  recipient         String
  eventKey          String
  channel           String
  status            String
  failureReason     String?
  renderedContent   String?
  idempotencyKey    String   @unique
  requestedBy       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template          CommunicationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateVersion   CommunicationTemplateVersion @relation(fields: [templateVersionId], references: [id])
}

model TenantKpiSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  period         String
  capturedAt     DateTime
  invites        Int      @default(0)
  responses      Int      @default(0)
  shortlisted    Int      @default(0)
  approved       Int      @default(0)
  onboarded      Int      @default(0)
  avgTimeToPublishHours Float @default(0)
  avgInviteToOnboardingHours Float @default(0)
  avgDecisionTimeHours Float @default(0)
  throughputPerHeadhunter Float @default(0)
  slaMet         Int      @default(0)
  slaBreached    Int      @default(0)
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, period, capturedAt])
}

model UserNotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(true)
  phoneEnabled          Boolean  @default(false)
  inAppEnabled          Boolean  @default(true)
  eventNewInvite        Boolean  @default(true)
  eventStepCompleted    Boolean  @default(true)
  eventDecision         Boolean  @default(true)
  eventReminder         Boolean  @default(true)
  eventAccessChange     Boolean  @default(true)
  eventCriticalAudit    Boolean  @default(true)
  frequency             String   @default("immediate")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateInvite {
  id             String       @id @default(cuid())
  organizationId String
  vacancyId      String
  candidateId    String
  channel        String
  destination    String
  status         String       @default("queued")
  dispatchId     String?
  invitedByUserId String
  failureReason  String?
  metadata       Json?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vacancy        Vacancy      @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  invitedBy      User         @relation("CandidateInviteActor", fields: [invitedByUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([vacancyId, status])
  @@index([candidateId, createdAt])
}

model NotificationDispatch {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  channel        String
  eventKey       String
  destination    String
  status         String       @default("queued")
  frequency      String       @default("immediate")
  failureReason  String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organizationId, eventKey, createdAt])
}

model CandidateProfile {
  id                    String    @id @default(cuid())
  candidateId           String    @unique
  fullName              String?
  phone                 String?
  photoUrl              String?
  photoProvider         String?
  socialName            String?
  socialEmail           String?
  locationCity          String?
  locationState         String?
  locationCountry       String?
  resumeSummary         String?
  introVideoKey         String?
  introVideoProvider    String?
  introVideoDurationSec Int?
  introVideoUploadedAt  DateTime?
  introVideoAnalysisStatus String?
  introVideoTranscript     String?
  introVideoTranscriptLanguage String?
  introVideoSummary        String?
  introVideoTags           Json?
  introVideoSentimentJson  Json?
  introVideoEntitiesJson   Json?
  introVideoKeyPhrasesJson Json?
  introVideoAnalyzedAt     DateTime?
  candidate             Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  experiences           CandidateExperience[]
  educations            CandidateEducation[]
  skills                CandidateSkill[]
  languages             CandidateLanguage[]
}

model CandidateExperience {
  id          String           @id @default(cuid())
  profileId   String
  company     String
  role        String
  period      String?
  description String?
  source      String           @default("cv-parse")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model CandidateEducation {
  id          String           @id @default(cuid())
  profileId   String
  institution String
  degree      String
  field       String?
  period      String?
  source      String           @default("cv-parse")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model CandidateSkill {
  id        String           @id @default(cuid())
  profileId String
  name      String
  level     String?
  source    String           @default("cv-parse")
  createdAt DateTime         @default(now())
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, name])
  @@index([profileId])
}

model CandidateLanguage {
  id        String           @id @default(cuid())
  profileId String
  name      String
  level     String?
  source    String           @default("cv-parse")
  createdAt DateTime         @default(now())
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, name])
  @@index([profileId])
}

model Application {
  id          String       @id @default(cuid())
  candidateId String
  vacancyId   String
  status      String       @default("submitted")
  createdAt   DateTime     @default(now())
  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancy     Vacancy      @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  evaluations Evaluation[]
  shortlistItems ShortlistItem[]
  smartInterviewSessions SmartInterviewSession[]

  @@unique([candidateId, vacancyId])
  @@index([vacancyId, status])
}

model CandidateOnboardingSession {
  id                    String              @id @default(cuid())
  candidateId           String              @unique
  basicCompleted        Boolean             @default(false)
  consentCompleted      Boolean             @default(false)
  resumeCompleted       Boolean             @default(false)
  preferencesCompleted  Boolean             @default(false)
  introVideoCompleted   Boolean             @default(false)
  status                String              @default("pending")
  candidate             Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  consents              CandidateConsent[]
  resumes               CandidateResume[]
}

model CandidateConsent {
  id            String                      @id @default(cuid())
  sessionId     String
  type          String
  accepted      Boolean
  acceptedAt    DateTime                    @default(now())
  session       CandidateOnboardingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model CandidatePreferences {
  id          String    @id @default(cuid())
  candidateId String    @unique
  salaryMin   Int?
  salaryMax   Int?
  jobTitles   String[]
  languages   String[]
  workModelPreference String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateResume {
  id            String                      @id @default(cuid())
  sessionId     String
  objectKey     String
  provider      String
  status        String                      @default("uploaded")
  uploadedAt    DateTime                    @default(now())
  session       CandidateOnboardingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parseResult   ResumeParseResult?
  parseMetadata ResumeParseMetadata?
}

model ResumeParseResult {
  id          String          @id @default(cuid())
  resumeId    String          @unique
  status      String
  parsedJson  Json
  createdAt   DateTime        @default(now())
  resume      CandidateResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Shortlist {
  id          String          @id @default(cuid())
  vacancyId   String          @unique
  createdAt   DateTime        @default(now())
  vacancy     Vacancy         @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  items       ShortlistItem[]
}

model ShortlistItem {
  id            String       @id @default(cuid())
  shortlistId   String
  applicationId String
  createdAt     DateTime     @default(now())
  shortlist     Shortlist    @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  decisions     ClientDecision[]

  @@unique([shortlistId, applicationId])
}

model Evaluation {
  id                  String       @id @default(cuid())
  applicationId       String
  evaluatorId         String
  comment             String
  ratingTechnical     Int?
  ratingBehavioral    Int?
  ratingInterviewer   Int?
  ratingAi            Int?
  overallRating       Float?
  createdAt           DateTime     @default(now())
  application         Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  evaluator           User         @relation(fields: [evaluatorId], references: [id])
}

model ClientDecision {
  id             String        @id @default(cuid())
  shortlistItemId String
  reviewerId     String?
  decision       String
  createdAt      DateTime      @default(now())
  shortlistItem  ShortlistItem @relation(fields: [shortlistItemId], references: [id], onDelete: Cascade)
  reviewer       User?         @relation("ClientReviewer", fields: [reviewerId], references: [id])
}

model ClientReviewSession {
  id             String    @id @default(cuid())
  token          String    @unique
  vacancyId      String
  organizationId String
  createdByUserId String
  expiresAt      DateTime
  accessedAt     DateTime?
  createdAt      DateTime  @default(now())
  vacancy        Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([vacancyId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

model MessageDispatch {
  id          String   @id @default(cuid())
  channel     String
  destination String
  content     String
  status      String   @default("queued")
  createdAt   DateTime @default(now())
  events      MessageEvent[]
}

model OutboxEvent {
  id          String   @id @default(cuid())
  topic       String
  payload     Json
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([topic, processed, createdAt])
}

model VacancyTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  sector         String
  role           String
  version        Int      @default(1)
  status         String   @default("draft")
  isFavorite     Boolean  @default(false)
  usageCount     Int      @default(0)
  defaultFields  Json
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  vacancyId      String?
  vacancy        Vacancy? @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  versions       VacancyTemplateVersion[]

  @@index([organizationId, status])
}

model VacancyTemplateVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  status      String
  fields      Json
  createdBy   String
  createdAt   DateTime @default(now())
  template    VacancyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
}

model InviteFollowUpCadence {
  id             String   @id @default(cuid())
  organizationId String
  vacancyId      String
  candidateId    String
  applicationId  String?
  channelPlan    Json
  status         String   @default("active")
  pausedUntil    DateTime?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  attempts       InviteFollowUpAttempt[]

  @@unique([candidateId, vacancyId])
  @@index([organizationId, status])
}

model InviteFollowUpAttempt {
  id          String   @id @default(cuid())
  cadenceId   String
  stepKey     String
  channel     String
  status      String   @default("queued")
  scheduledAt DateTime
  sentAt      DateTime?
  metadata    Json
  createdAt   DateTime @default(now())
  cadence     InviteFollowUpCadence @relation(fields: [cadenceId], references: [id], onDelete: Cascade)

  @@unique([cadenceId, stepKey])
  @@index([status, scheduledAt])
}

model AuthIdentity {
  id           String   @id @default(cuid())
  provider     String
  subject      String
  email        String?
  passwordHash String?
  userId       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
}

model UserSession {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  provider   String
  expiresAt  DateTime
  revokedAt  DateTime?
  metadata   Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuestSession {
  id         String    @id @default(cuid())
  candidateId String   @unique
  token      String    @unique
  expiresAt  DateTime
  upgradedAt DateTime?
  createdAt  DateTime  @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model MfaPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  enabled        Boolean  @default(false)
  preferredMethod String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model SmartInterviewTemplate {
  id             String   @id @default(cuid())
  vacancyId      String   @unique
  configJson     Json
  status         String   @default("draft")
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  vacancy        Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  questions      SmartInterviewQuestion[]
  sessions       SmartInterviewSession[]
}

model SmartInterviewQuestion {
  id          String   @id @default(cuid())
  templateId  String
  orderIndex  Int
  prompt      String
  maxDuration Int      @default(120)
  source      String   @default("manual")
  createdAt   DateTime @default(now())
  template    SmartInterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers     SmartInterviewAnswer[]

  @@unique([templateId, orderIndex])
}

model SmartInterviewSession {
  id            String   @id @default(cuid())
  applicationId String   @unique
  templateId    String
  publicToken   String   @unique
  status        String   @default("draft")
  startedAt     DateTime?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  template      SmartInterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers       SmartInterviewAnswer[]
  aiAnalysis    SmartInterviewAiAnalysis?
  humanReview   SmartInterviewHumanReview?
}

model SmartInterviewAnswer {
  id           String   @id @default(cuid())
  sessionId     String
  questionId    String
  candidateId   String
  objectKey     String
  provider      String
  durationSec   Int?
  status        String   @default("uploaded")
  uploadedAt    DateTime @default(now())
  processedAt   DateTime?
  session       SmartInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question      SmartInterviewQuestion @relation(fields: [questionId], references: [id])
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  transcript    SmartInterviewTranscript?
  transcriptMeta TranscriptMetadata?

  @@unique([sessionId, questionId])
}

model SmartInterviewTranscript {
  id          String   @id @default(cuid())
  answerId    String   @unique
  status      String   @default("pending")
  content     String
  language    String   @default("pt-BR")
