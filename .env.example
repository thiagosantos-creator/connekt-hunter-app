DATABASE_URL=postgresql://postgres:postgres@localhost:5432/connekt
APP_ENV=local

# Feature flags - real integrations (default false for local)
FF_STORAGE_REAL=false
FF_EMAIL_REAL=false
FF_AUTH_REAL=false
FF_AI_REAL=false
FF_CV_PARSER_REAL=false
FF_TRANSCRIPTION_REAL=false

# Fallback control
STORAGE_FALLBACK_TO_MOCK=true
EMAIL_FALLBACK_TO_MOCK=true
AUTH_FALLBACK_TO_MOCK=true
AI_FALLBACK_TO_MOCK=true
CV_PARSER_FALLBACK_TO_MOCK=true
TRANSCRIPTION_FALLBACK_TO_MOCK=true

# Explicit provider override (optional)
STORAGE_PROVIDER=auto
EMAIL_PROVIDER=auto
AUTH_PROVIDER=auto
AI_PROVIDER=auto
CV_PARSER_PROVIDER=auto
TRANSCRIPTION_PROVIDER=auto

# AWS S3 / MinIO
S3_REGION=us-east-1
S3_BUCKET=connekt-staging-assets
AWS_ACCESS_KEY_ID=__REPLACE_ME__
AWS_SECRET_ACCESS_KEY=__REPLACE_ME__

# AWS SES
SES_REGION=us-east-1
SES_FROM_EMAIL=__REPLACE_ME__

# AWS Cognito (backoffice — admin/headhunter/client)
COGNITO_USER_POOL_ID=__REPLACE_ME__
COGNITO_CLIENT_ID=__REPLACE_ME__

# AWS Cognito — Candidate Pool (separate pool with Google/LinkedIn social login)
COGNITO_CANDIDATE_POOL_ID=__REPLACE_ME__
COGNITO_CANDIDATE_CLIENT_ID=__REPLACE_ME__
COGNITO_CANDIDATE_DOMAIN=__REPLACE_ME__
COGNITO_CANDIDATE_REDIRECT_URI=http://localhost:5174/auth/callback

# AI
AI_MODEL_VERSION=gpt-4.1-mini
AI_PROVIDER_API_KEY=__REPLACE_ME__
OPENAI_API_KEY=__REPLACE_ME__

# AWS Transcribe
AWS_TRANSCRIBE_REGION=us-east-1

# AWS Comprehend (sentiment analysis)
AWS_COMPREHEND_REGION=us-east-1

# CV parser and transcription gateways
CV_PARSER_API_URL=__REPLACE_ME__
CV_PARSER_API_KEY=__REPLACE_ME__
TRANSCRIPTION_API_URL=__REPLACE_ME__
TRANSCRIPTION_API_KEY=__REPLACE_ME__

# Redis (rate limiting + token cache)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=30
PUBLIC_TOKEN_CACHE_TTL_SEC=30
