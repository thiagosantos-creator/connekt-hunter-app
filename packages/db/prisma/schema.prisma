  vacancy              Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  suggestion           WorkflowSuggestion? @relation(fields: [workflowSuggestionId], references: [id], onDelete: SetNull)

  @@index([vacancyId, status])
}

